# PWC Geohub — local environment variables (server-side only)
# Pull from Vercel after linking the project: `vercel env pull .env.local`

# Neon Postgres (provisioned via Vercel Marketplace → Storage → Neon)
# Vercel sets DATABASE_URL automatically; the pooled URL is preferred for ETL.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Blob (provisioned via Vercel Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# US Census API key — free, instant: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# CDC PLACES (Socrata) — optional; raises rate limits, not required
CDC_APP_TOKEN=

# Optional: ETL run identifier (used in reports/data_quality_findings)
ETL_RUN_ID=
